# ──────────────────────────────────────────────────────────────────────────────
# EcoCribs Documentation Portal — environment template
# Copy to .env.local for the web app; Convex pulls its own from `convex env set`.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Convex ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=

# ─── Clerk ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# ─── Cloudflare R2 (set via `convex env set …` for backend) ─────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ecocribs-documents
R2_PUBLIC_BASE_URL=https://docs.ecocribsrealty.com
R2_SIGNED_URL_SECRET=

# ─── Twilio WhatsApp Business ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_SIGNING_SECRET=

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=EcoCribs Portal <noreply@ecocribsrealty.com>
RESEND_WEBHOOK_SECRET=

# ─── Smile Identity (KYC) ───────────────────────────────────────────────────
SMILE_PARTNER_ID=
SMILE_API_KEY=
SMILE_ENVIRONMENT=sandbox

# ─── Documenso (e-signature, self-hosted) ───────────────────────────────────
DOCUMENSO_BASE_URL=https://sign.ecocribsrealty.com
DOCUMENSO_API_KEY=

# ─── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=ecocribs
SENTRY_PROJECT=portal-web

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://portal.ecocribsrealty.com
NEXT_PUBLIC_BRAND_HOST_URL=https://ecocribsrealty.com
NEXT_PUBLIC_SUPPORT_EMAIL=help@ecocribsrealty.com
NEXT_PUBLIC_SUPPORT_PHONE=+2348157144444
