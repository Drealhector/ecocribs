# Local preview template — copy to .env.local for dev.
# In dev we render with seed data so you don't need a live Convex backend.

# Preview mode flag. Set to false (or unset) in production.
NEXT_PUBLIC_PREVIEW_MODE=true

# Convex deployment URL — placeholder is fine in preview mode.
NEXT_PUBLIC_CONVEX_URL=https://example.convex.cloud

# App URL (used for OAuth callbacks, share links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
