# ─── Production deployment template ───
# Replace every placeholder. Set these in Vercel project settings.

# Convex (from `npx convex deploy` output)
NEXT_PUBLIC_CONVEX_URL=https://your-prod.convex.cloud
CONVEX_DEPLOYMENT=prod:your-name

# Convex Auth (auto-generated by `npx convex auth init` or set manually)
SITE_URL=https://portal.ecocribsrealty.com
JWT_PRIVATE_KEY=
JWKS=

# WhatsApp + Email (phase 2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
RESEND_API_KEY=
RESEND_FROM=EcoCribs <noreply@ecocribsrealty.com>

# File storage (phase 2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ecocribs-documents

# KYC (phase 2)
SMILE_PARTNER_ID=
SMILE_API_KEY=

# ─── App config ───
NEXT_PUBLIC_APP_URL=https://portal.ecocribsrealty.com
NEXT_PUBLIC_BRAND_HOST_URL=https://ecocribsrealty.com
NEXT_PUBLIC_SUPPORT_EMAIL=help@ecocribsrealty.com
