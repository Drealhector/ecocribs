{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ESNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": { "@convex/*": ["./*"] }
  },
  "include": ["./**/*.ts"],
  "exclude": ["./_generated"]
}
